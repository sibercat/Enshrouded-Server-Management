<Window x:Class="EnshroudedServerManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <StackPanel Margin="20">
        <TextBlock Text="Enshrouded Server Manager" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
        <TextBlock x:Name="VersionText" FontSize="13" Margin="0,0,0,6"/>
        <TextBlock FontSize="13" Margin="0,0,0,6">
            <Run Text="Created by: "/>
            <Hyperlink NavigateUri="https://github.com/sibercat" RequestNavigate="Hyperlink_RequestNavigate">
                Sibercat
            </Hyperlink>
        </TextBlock>
        <TextBlock FontSize="13" Margin="0,0,0,20">
            <Run Text="GitHub: "/>
            <Hyperlink x:Name="GitHubLink"
                       NavigateUri="https://github.com/sibercat/Enshrouded-Server-Management"
                       RequestNavigate="Hyperlink_RequestNavigate">
                github.com/sibercat/Enshrouded-Server-Management
            </Hyperlink>
        </TextBlock>
        <Button Content="OK" Width="80" HorizontalAlignment="Right" Click="OkBtn_Click"/>
    </StackPanel>
</Window>
