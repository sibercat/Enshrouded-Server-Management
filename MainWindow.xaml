<Window x:Class="EnshroudedServerManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enshrouded Server Manager v1.0.0" Icon="app.ico"
        MinWidth="900" MinHeight="700" Width="1000" Height="750"
        Closing="Window_Closing">

    <DockPanel LastChildFill="True">

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Help">
                <MenuItem Header="Check for Updates" Click="CheckForUpdates_Click"/>
                <Separator/>
                <MenuItem Header="About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status header -->
        <GroupBox Header="Server Status" DockPanel.Dock="Top" Margin="6,6,6,3">
            <StackPanel Margin="6,4">
                <WrapPanel>
                    <TextBlock Text="Status: " FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusIndicator" Text="Stopped" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionLabel" Text="  |  Server Version: Unknown" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#555"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <TextBlock x:Name="ServerNameLabel" Text="Server: —" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PlayerCountLabel" Text="" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#555"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Main tabs -->
        <TabControl Margin="6,3,6,6">

            <!-- ═══════════════ SERVER CONTROL ═══════════════ -->
            <TabItem Header="Server Control">
                <DockPanel LastChildFill="True" Margin="6">
                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Button x:Name="StartBtn"   Content="▶  Start Server"   Width="140" Height="32" Margin="0,0,6,0" Click="StartBtn_Click"/>
                        <Button x:Name="StopBtn"    Content="■  Stop Server"    Width="140" Height="32" Margin="0,0,6,0" Click="StopBtn_Click"/>
                        <Button x:Name="RestartBtn" Content="↺  Restart Server" Width="140" Height="32" Margin="0,0,6,0" Click="RestartBtn_Click"/>
                        <Button x:Name="UpdateBtn"  Content="↓  Update Server"  Width="140" Height="32" Margin="0,0,6,0" Click="UpdateBtn_Click"/>
                        <Button x:Name="FirewallBtn" Content="🛡  Setup Firewall" Width="140" Height="32" Click="FirewallBtn_Click"
                                ToolTip="Add Windows Firewall inbound UDP rules for the game port and query port."/>
                    </WrapPanel>
                    <GroupBox Header="Performance" DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid Margin="6,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CpuLabel"    Grid.Row="0" Grid.Column="0" Text="CPU: 0%"    VerticalAlignment="Center"/>
                            <ProgressBar x:Name="CpuBar"   Grid.Row="0" Grid.Column="1" Height="20" Minimum="0" Maximum="100"/>
                            <TextBlock x:Name="MemoryLabel" Grid.Row="2" Grid.Column="0" Text="Memory: 0 MB" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="MemoryBar" Grid.Row="2" Grid.Column="1" Height="20" Minimum="0" Maximum="32768"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Console Output">
                        <TextBox x:Name="ConsoleOutput" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Consolas" FontSize="12"
                                 Background="#1E1E1E" Foreground="#D4D4D4" Padding="4"/>
                    </GroupBox>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ SETTINGS (nested tabs) ═══════════════ -->
            <TabItem Header="Settings">
                <TabControl Margin="2">

                    <!-- ─── Server sub-tab ─── -->
                    <TabItem Header="Server">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6">

                                <!-- Identity -->
                                <GroupBox Header="Server Identity" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Server Name:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ServerNameInput" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Server IP:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ServerIpInput" Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Game Port:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="GamePortInput" Grid.Row="1" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Query Port:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="QueryPortInput" Grid.Row="2" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Max Players (1-16):" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="MaxPlayersInput" Grid.Row="2" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Startup Params:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="StartupParamsInput" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Launch options -->
                                <GroupBox Header="Launch Options" Margin="0,0,0,6">
                                    <StackPanel Margin="6,4" Orientation="Horizontal">
                                        <CheckBox x:Name="PvpEnabledCheck" Content="Enable PvP" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        <TextBlock Text="Max FPS:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox x:Name="MaxFpsInput" Width="60" Margin="0,0,20,0"/>
                                        <TextBlock Text="Tick Rate:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox x:Name="TickRateInput" Width="60"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Voice & Chat -->
                                <GroupBox Header="Voice &amp; Chat" Margin="0,0,0,6">
                                    <StackPanel Margin="6,4">
                                        <WrapPanel Margin="0,4">
                                            <CheckBox x:Name="EnableVoiceChatCheck" Content="Enable Voice Chat" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                            <CheckBox x:Name="EnableTextChatCheck"  Content="Enable Text Chat"  VerticalAlignment="Center"/>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4">
                                            <TextBlock Text="Voice Chat Mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="VoiceChatModeCombo" Width="120">
                                                <ComboBoxItem Content="Proximity"/>
                                                <ComboBoxItem Content="Global"/>
                                            </ComboBox>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Server Tags -->
                                <GroupBox Header="Server Tags" Margin="0,0,0,6">
                                    <WrapPanel Margin="6,4">
                                        <CheckBox x:Name="TagLookingForPlayers" Content="LookingForPlayers" Margin="4"/>
                                        <CheckBox x:Name="TagBaseBuilding"      Content="BaseBuilding"      Margin="4"/>
                                        <CheckBox x:Name="TagExploration"       Content="Exploration"       Margin="4"/>
                                        <CheckBox x:Name="TagRoleplay"          Content="Roleplay"          Margin="4"/>
                                        <CheckBox x:Name="TagEnglish"    Content="English"    Margin="4"/>
                                        <CheckBox x:Name="TagGerman"     Content="German"     Margin="4"/>
                                        <CheckBox x:Name="TagFrench"     Content="French"     Margin="4"/>
                                        <CheckBox x:Name="TagItalian"    Content="Italian"    Margin="4"/>
                                        <CheckBox x:Name="TagJapanese"   Content="Japanese"   Margin="4"/>
                                        <CheckBox x:Name="TagKorean"     Content="Korean"     Margin="4"/>
                                        <CheckBox x:Name="TagPolish"     Content="Polish"     Margin="4"/>
                                        <CheckBox x:Name="TagPortuguese" Content="Portuguese" Margin="4"/>
                                        <CheckBox x:Name="TagRussian"    Content="Russian"    Margin="4"/>
                                        <CheckBox x:Name="TagSpanish"    Content="Spanish"    Margin="4"/>
                                        <CheckBox x:Name="TagThai"       Content="Thai"       Margin="4"/>
                                        <CheckBox x:Name="TagTurkish"    Content="Turkish"    Margin="4"/>
                                        <CheckBox x:Name="TagUkrainian"  Content="Ukrainian"  Margin="4"/>
                                        <CheckBox x:Name="TagChinese"    Content="Chinese"    Margin="4"/>
                                        <CheckBox x:Name="TagTaiwanese"  Content="Taiwanese"  Margin="4"/>
                                    </WrapPanel>
                                </GroupBox>

                                <!-- Scheduled Restart -->
                                <GroupBox Header="Scheduled Restart" Margin="0,0,0,6">
                                    <StackPanel Margin="6,4">
                                        <CheckBox x:Name="AutoRestartCheck" Content="Enable Scheduled Restart" Margin="0,4"
                                                  ToolTip="Automatically restart the server on a recurring schedule."/>
                                        <WrapPanel Margin="0,4">
                                            <TextBlock Text="Restart Interval (hours):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="RestartIntervalInput" Width="70" Margin="0,0,18,0"/>
                                            <TextBlock Text="Warning Time (minutes):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="RestartWarningInput" Width="70"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="NextRestartLabel" Text="Next Restart: Not scheduled" Foreground="#555" Margin="0,4"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Crash Restart -->
                                <GroupBox Header="Crash Restart" Margin="0,0,0,6">
                                    <StackPanel Margin="6,4">
                                        <CheckBox x:Name="AutoRestartOnCrashCheck" Content="Auto Restart on Crash" Margin="0,4"
                                                  ToolTip="Automatically restart the server if it crashes or disappears unexpectedly."/>
                                        <WrapPanel Margin="0,4">
                                            <TextBlock Text="Delay before restart (seconds):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="CrashRestartDelayInput" Width="70"
                                                     ToolTip="How long to wait before restarting after a crash (default: 10 seconds)."/>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Discord Webhook -->
                                <GroupBox Header="Discord Notifications" Margin="0,0,0,6">
                                    <StackPanel Margin="6,4">
                                        <TextBlock Text="Status Webhook URL:" Margin="0,0,0,4"/>
                                        <TextBox x:Name="DiscordStatusWebhookInput" Width="420" HorizontalAlignment="Left"
                                                 ToolTip="Webhook for routine events: server started, stopped, and restart warnings. Leave blank to disable."/>
                                        <TextBlock Foreground="#888" FontSize="11" Margin="0,2,0,8"
                                                   Text="Fires on: started, stopped, 5 min before restart."/>
                                        <TextBlock Text="Crash Webhook URL:" Margin="0,0,0,4"/>
                                        <TextBox x:Name="DiscordCrashWebhookInput" Width="420" HorizontalAlignment="Left"
                                                 ToolTip="Webhook for crash alerts only. Point this at a separate channel or use a role ping. Leave blank to disable."/>
                                        <TextBlock Foreground="#888" FontSize="11" Margin="0,2,0,0"
                                                   Text="Fires on: unexpected crash only."/>
                                    </StackPanel>
                                </GroupBox>

                                <Button Content="Save Settings" Width="140" Height="30" HorizontalAlignment="Left" Margin="0,4,0,8" Click="SaveSettingsBtn_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ─── Gameplay sub-tab ─── -->
                    <TabItem Header="Gameplay">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6">

                                <!-- Difficulty preset -->
                                <GroupBox Header="Difficulty Preset" Margin="0,0,0,6">
                                    <WrapPanel Margin="6,6">
                                        <TextBlock Text="Game Settings Preset:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="GamePresetCombo" Width="150" SelectionChanged="GamePresetCombo_SelectionChanged">
                                            <ComboBoxItem Content="Default"/>
                                            <ComboBoxItem Content="Relaxed"/>
                                            <ComboBoxItem Content="Hard"/>
                                            <ComboBoxItem Content="Survival"/>
                                            <ComboBoxItem Content="Custom"/>
                                        </ComboBox>
                                        <Button Content="Reset to Defaults" Margin="12,0,0,0" Padding="8,2"
                                                Click="ResetGameSettingsBtn_Click"
                                                ToolTip="Reset all gameplay settings to their default values and switch preset to Default."/>
                                    </WrapPanel>
                                </GroupBox>

                                <!-- Player stats -->
                                <GroupBox Header="Player Stats" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Health Factor (0.25-4):"   VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="PlayerHealthInput"    Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Mana Factor (0.25-4):"    VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="PlayerManaInput"      Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Stamina Factor (0.25-4):" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="PlayerStaminaInput"   Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Body Heat Factor (0.5-2):" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="PlayerBodyHeatInput"  Grid.Row="1" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Diving Time Factor (0.5-2):" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="PlayerDivingInput"    Grid.Row="2" Grid.Column="1" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Survival -->
                                <GroupBox Header="Survival" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <CheckBox x:Name="EnableDurabilityCheck"   Grid.Row="0" Grid.Column="0" Content="Enable Weapon Durability" VerticalAlignment="Center" Margin="0,4"/>
                                        <CheckBox x:Name="EnableStarvingCheck"     Grid.Row="0" Grid.Column="2" Content="Enable Starving Debuff"   VerticalAlignment="Center" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Food Buff Duration (0.5-2):"  VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="FoodBuffDurationInput"    Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Hunger→Starving (min 5-20):" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="HungerToStarvingInput"    Grid.Row="1" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Shroud Time Factor (0.5-2):" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ShroudTimeInput"          Grid.Row="2" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Tombstone Mode:"            VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <ComboBox x:Name="TombstoneModeCombo" Grid.Row="2" Grid.Column="3" Margin="5,4">
                                            <ComboBoxItem Content="AddBackpackMaterials"/>
                                            <ComboBoxItem Content="Everything"/>
                                            <ComboBoxItem Content="NoTombstone"/>
                                        </ComboBox>
                                    </Grid>
                                </GroupBox>

                                <!-- World & Environment -->
                                <GroupBox Header="World &amp; Environment" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Weather Frequency:"  VerticalAlignment="Center" Margin="0,4"/>
                                        <ComboBox x:Name="WeatherFreqCombo" Grid.Row="0" Grid.Column="1" Margin="5,4">
                                            <ComboBoxItem Content="Disabled"/>
                                            <ComboBoxItem Content="Rare"/>
                                            <ComboBoxItem Content="Normal"/>
                                            <ComboBoxItem Content="Often"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Fishing Difficulty:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <ComboBox x:Name="FishingDifficultyCombo" Grid.Row="0" Grid.Column="3" Margin="5,4">
                                            <ComboBoxItem Content="VeryEasy"/>
                                            <ComboBoxItem Content="Easy"/>
                                            <ComboBoxItem Content="Normal"/>
                                            <ComboBoxItem Content="Hard"/>
                                            <ComboBoxItem Content="VeryHard"/>
                                        </ComboBox>
                                        <CheckBox x:Name="EnableGliderCheck" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Enable Glider Turbulences" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mining Damage (0.5-2):"       VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="MiningDamageInput"    Grid.Row="2" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Plant Growth (0.25-2):"       VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="PlantGrowthInput"     Grid.Row="2" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Day Length (min 2-60):"       VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="DayLengthInput"       Grid.Row="3" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Night Length (min 2-60):"     VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="NightLengthInput"     Grid.Row="3" Grid.Column="3" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Resources & Economy -->
                                <GroupBox Header="Resources &amp; Economy" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Resource Drop (0.25-2):"      VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ResourceDropInput"    Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Factory Speed (0.25-2):"      VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="FactorySpeedInput"    Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Perk Recycling (0-1):"        VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="PerkRecyclingInput"   Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Perk Cost (0.25-2):"          VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="PerkCostInput"        Grid.Row="1" Grid.Column="3" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Experience -->
                                <GroupBox Header="Experience" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Combat XP (0.25-2):"      VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="CombatXpInput"        Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Mining XP (0-2):"         VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="MiningXpInput"        Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Exploration XP (0.25-2):" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ExploreXpInput"       Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Enemies -->
                                <GroupBox Header="Enemies" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enemy Amount:"           VerticalAlignment="Center" Margin="0,4"/>
                                        <ComboBox x:Name="EnemyAmountCombo" Grid.Row="0" Grid.Column="1" Margin="5,4">
                                            <ComboBoxItem Content="Few"/>
                                            <ComboBoxItem Content="Normal"/>
                                            <ComboBoxItem Content="Many"/>
                                            <ComboBoxItem Content="Extreme"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Aggro Pool Amount:"      VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <ComboBox x:Name="AggroPoolCombo" Grid.Row="0" Grid.Column="3" Margin="5,4">
                                            <ComboBoxItem Content="Few"/>
                                            <ComboBoxItem Content="Normal"/>
                                            <ComboBoxItem Content="Many"/>
                                            <ComboBoxItem Content="Extreme"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enemy Damage (0.25-5):"  VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="EnemyDamageInput"     Grid.Row="1" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Enemy Health (0.25-4):"  VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="EnemyHealthInput"     Grid.Row="1" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Enemy Stamina (0.5-2):"  VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="EnemyStaminaInput"    Grid.Row="2" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Enemy Perception (0.5-2):" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="EnemyPerceptionInput" Grid.Row="2" Grid.Column="3" Margin="5,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Threat Bonus (0.25-4):"  VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="ThreatBonusInput"     Grid.Row="3" Grid.Column="1" Margin="5,4"/>
                                        <CheckBox x:Name="PacifyEnemiesCheck" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Content="Pacify All Enemies (no attacks)" VerticalAlignment="Center" Margin="5,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Taming Repercussion:"   VerticalAlignment="Center" Margin="0,4"/>
                                        <ComboBox x:Name="TamingRepercussionCombo" Grid.Row="4" Grid.Column="1" Margin="5,4">
                                            <ComboBoxItem Content="KeepProgress"/>
                                            <ComboBoxItem Content="LoseSomeProgress"/>
                                            <ComboBoxItem Content="LoseAllProgress"/>
                                        </ComboBox>
                                    </Grid>
                                </GroupBox>

                                <!-- Bosses -->
                                <GroupBox Header="Bosses" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Boss Damage (0.2-5):" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="BossDamageInput"     Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Boss Health (0.2-5):" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="BossHealthInput"     Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Misc -->
                                <GroupBox Header="Miscellaneous" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Curse Modifier:" VerticalAlignment="Center" Margin="0,4"/>
                                        <ComboBox x:Name="CurseModifierCombo" Grid.Row="0" Grid.Column="1" Margin="5,4">
                                            <ComboBoxItem Content="Easy"/>
                                            <ComboBoxItem Content="Normal"/>
                                            <ComboBoxItem Content="Hard"/>
                                        </ComboBox>
                                    </Grid>
                                </GroupBox>

                                <Button Content="Save Settings" Width="140" Height="30" HorizontalAlignment="Left" Margin="0,4,0,8" Click="SaveSettingsBtn_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ─── User Groups sub-tab ─── -->
                    <TabItem Header="User Groups">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6">
                                <TextBlock Text="Set passwords and permissions for each player role. Reserved Slots hold spots open for that group even when the server is full."
                                           TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#555"/>

                                <!-- Admin -->
                                <GroupBox Header="Admin" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="AdminPassInput" Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Reserved Slots:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="AdminReservedInput" Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4">
                                            <CheckBox x:Name="AdminCanKickBan"           Content="Can Kick/Ban"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="AdminCanAccessInventories" Content="Can Access Inventories" Margin="0,0,14,0"/>
                                            <CheckBox x:Name="AdminCanEditWorld"         Content="Can Edit World"         Margin="0,0,14,0"/>
                                            <CheckBox x:Name="AdminCanEditBase"          Content="Can Edit Base"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="AdminCanExtendBase"        Content="Can Extend Base"/>
                                        </WrapPanel>
                                    </Grid>
                                </GroupBox>

                                <!-- Friend -->
                                <GroupBox Header="Friend" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="FriendPassInput" Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Reserved Slots:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="FriendReservedInput" Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4">
                                            <CheckBox x:Name="FriendCanKickBan"           Content="Can Kick/Ban"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="FriendCanAccessInventories" Content="Can Access Inventories" Margin="0,0,14,0"/>
                                            <CheckBox x:Name="FriendCanEditWorld"         Content="Can Edit World"         Margin="0,0,14,0"/>
                                            <CheckBox x:Name="FriendCanEditBase"          Content="Can Edit Base"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="FriendCanExtendBase"        Content="Can Extend Base"/>
                                        </WrapPanel>
                                    </Grid>
                                </GroupBox>

                                <!-- Guest -->
                                <GroupBox Header="Guest" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="GuestPassInput" Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Reserved Slots:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="GuestReservedInput" Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4">
                                            <CheckBox x:Name="GuestCanKickBan"           Content="Can Kick/Ban"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="GuestCanAccessInventories" Content="Can Access Inventories" Margin="0,0,14,0"/>
                                            <CheckBox x:Name="GuestCanEditWorld"         Content="Can Edit World"         Margin="0,0,14,0"/>
                                            <CheckBox x:Name="GuestCanEditBase"          Content="Can Edit Base"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="GuestCanExtendBase"        Content="Can Extend Base"/>
                                        </WrapPanel>
                                    </Grid>
                                </GroupBox>

                                <!-- Visitor -->
                                <GroupBox Header="Visitor" Margin="0,0,0,6">
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                                        <TextBox x:Name="VisitorPassInput" Grid.Row="0" Grid.Column="1" Margin="5,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Reserved Slots:" VerticalAlignment="Center" Margin="5,4,0,4"/>
                                        <TextBox x:Name="VisitorReservedInput" Grid.Row="0" Grid.Column="3" Margin="5,4"/>
                                        <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4">
                                            <CheckBox x:Name="VisitorCanKickBan"           Content="Can Kick/Ban"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="VisitorCanAccessInventories" Content="Can Access Inventories" Margin="0,0,14,0"/>
                                            <CheckBox x:Name="VisitorCanEditWorld"         Content="Can Edit World"         Margin="0,0,14,0"/>
                                            <CheckBox x:Name="VisitorCanEditBase"          Content="Can Edit Base"          Margin="0,0,14,0"/>
                                            <CheckBox x:Name="VisitorCanExtendBase"        Content="Can Extend Base"/>
                                        </WrapPanel>
                                    </Grid>
                                </GroupBox>

                                <Button Content="Save Settings" Width="140" Height="30" HorizontalAlignment="Left" Margin="0,4,0,8" Click="SaveSettingsBtn_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </TabItem>

            <!-- ═══════════════ BACKUP ═══════════════ -->
            <TabItem Header="Backup">
                <DockPanel LastChildFill="True" Margin="6">
                    <StackPanel DockPanel.Dock="Top">
                        <GroupBox Header="Backup Settings" Margin="0,0,0,6">
                            <StackPanel Margin="6,4">
                                <CheckBox x:Name="AutoBackupCheck" Content="Enable Auto-Backup" Margin="0,4"/>
                                <WrapPanel Margin="0,4">
                                    <TextBlock Text="Backup Interval (minutes):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="BackupIntervalInput" Width="70" Margin="0,0,18,0"/>
                                    <TextBlock Text="Keep Backups (days):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="RetentionDaysInput" Width="70"/>
                                </WrapPanel>
                                <CheckBox x:Name="BackupOnShutdownCheck" Content="Backup on Server Shutdown" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>
                        <WrapPanel Margin="0,0,0,6">
                            <Button Content="Create Backup Now" Width="150" Height="30" Margin="0,0,8,0" Click="CreateBackupBtn_Click"/>
                            <Button Content="Save Settings"     Width="140" Height="30" Click="SaveSettingsBtn_Click"/>
                        </WrapPanel>
                        <TextBlock x:Name="NextBackupLabel" Text="Next Backup: Not scheduled" Margin="0,0,0,6" Foreground="#555"/>
                    </StackPanel>
                    <GroupBox Header="Existing Backups">
                        <DockPanel>
                            <Button Content="Refresh Backup List" DockPanel.Dock="Bottom" Height="30" Margin="0,6,0,0" Click="RefreshBackupBtn_Click"/>
                            <TextBox x:Name="BackupList" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"/>
                        </DockPanel>
                    </GroupBox>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ LOGS ═══════════════ -->
            <TabItem Header="Logs">
                <DockPanel LastChildFill="True" Margin="6">
                    <Button Content="Refresh Logs" DockPanel.Dock="Bottom" Height="30" Margin="0,6,0,0" Click="RefreshLogsBtn_Click"/>
                    <GroupBox Header="Server Logs">
                        <TextBox x:Name="LogViewer" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                    </GroupBox>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
